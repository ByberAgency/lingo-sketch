# Google Cloud SQL PostgreSQL — live database used for local dev and production
# Instance: lingo-sketch (me-central1), public IP: 34.18.21.85
# URL-encode special characters in the password (# % ^ ` etc.)
DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@34.18.21.85:5432/lingo_sketch?sslmode=require
DATABASE_SSL=true

# API
PORT=3000
DASHBOARD_URL=http://localhost:5173

# Gemini (AI grammar guard)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Firebase Admin (backend) — use PATH for local dev, JSON for Cloud Run / Secret Manager
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/lingo-sketch-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Dashboard
VITE_API_URL=http://localhost:3000

# Mobile (Expo) — use LAN IP for physical devices, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Firebase Web SDK (dashboard) — from Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-app-id
