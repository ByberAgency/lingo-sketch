{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DATABASE_SSL",
    "PORT",
    "VITE_API_URL",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_FIREBASE_API_KEY",
    "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN",
    "EXPO_PUBLIC_FIREBASE_PROJECT_ID",
    "EXPO_PUBLIC_FIREBASE_APP_ID",
    "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID"
  ],
  "tasks": {
    "openapi:generate": {
      "dependsOn": [],
      "cache": false,
      "outputs": ["openapi.json"]
    },
    "generate": {
      "dependsOn": ["^openapi:generate"],
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "db:generate": {
      "dependsOn": [],
      "cache": false
    },
    "db:migrate": {
      "dependsOn": [],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {}
  }
}
